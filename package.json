{
  "name": "laravel-api-generator",
  "displayName": "Laravel API Generator",
  "description": "Generate complete REST APIs for Laravel with a visual interface",
  "version": "0.9.0",
  "publisher": "Nameless0l",
  "license": "MIT",
  "icon": "media/icon-marketplace.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nameless0l/laravel-api-generator-vscode"
  },
  "homepage": "https://github.com/Nameless0l/laravel-api-generator-vscode#readme",
  "bugs": {
    "url": "https://github.com/Nameless0l/laravel-api-generator-vscode/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "laravel",
    "php",
    "api",
    "crud",
    "rest api",
    "code generator",
    "artisan",
    "eloquent",
    "scaffold",
    "backend"
  ],
  "activationEvents": [
    "workspaceContains:artisan",
    "workspaceContains:*/artisan",
    "workspaceContains:*/*/artisan"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "laravelApiGenerator.generate",
        "title": "Generate Full API",
        "category": "Laravel API Generator",
        "icon": "$(add)"
      },
      {
        "command": "laravelApiGenerator.delete",
        "title": "Delete Full API",
        "category": "Laravel API Generator",
        "icon": "$(trash)"
      },
      {
        "command": "laravelApiGenerator.regenerateFile",
        "title": "Regenerate File(s)...",
        "category": "Laravel API Generator",
        "icon": "$(sync)"
      },
      {
        "command": "laravelApiGenerator.refresh",
        "title": "Refresh Entities",
        "category": "Laravel API Generator",
        "icon": "$(refresh)"
      },
      {
        "command": "laravelApiGenerator.goToRelated",
        "title": "Go to Related File",
        "category": "Laravel API Generator"
      },
      {
        "command": "laravelApiGenerator.diagram",
        "title": "Show Entity Diagram",
        "category": "Laravel API Generator",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "laravelApiGenerator.showSnippets",
        "title": "Show Snippets",
        "category": "Laravel API Generator",
        "icon": "$(symbol-snippet)"
      },
      {
        "command": "laravelApiGenerator.generateFromDatabase",
        "title": "Generate APIs from Database",
        "category": "Laravel API Generator",
        "icon": "$(database)"
      },
      {
        "command": "laravelApiGenerator.generateFromSchema",
        "title": "Generate APIs from Schema File (api-schema.yaml)",
        "category": "Laravel API Generator",
        "icon": "$(file-code)"
      },
      {
        "command": "laravelApiGenerator.generateFromMermaid",
        "title": "Generate APIs from Mermaid Diagram",
        "category": "Laravel API Generator",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "laravelApiGenerator.addFields",
        "title": "Add Fields to Entity...",
        "category": "Laravel API Generator",
        "icon": "$(diff-added)"
      }
    ],
    "snippets": [
      {
        "language": "php",
        "path": "./snippets/laravel-api-generator.json"
      }
    ],
    "keybindings": [
      {
        "command": "laravelApiGenerator.goToRelated",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laravelApiGenerator",
          "title": "Laravel API Generator",
          "icon": "media/icon-dark.png"
        }
      ]
    },
    "views": {
      "laravelApiGenerator": [
        {
          "id": "laravelApiGenerator.entities",
          "name": "Generated Entities"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "laravelApiGenerator.entities",
        "contents": "No generated APIs found in this project yet.\n[$(add) Generate your first API](command:laravelApiGenerator.generate)\n[$(database) Import from Database](command:laravelApiGenerator.generateFromDatabase)\n[$(file-code) Generate from Schema File](command:laravelApiGenerator.generateFromSchema)\nLearn more in the [documentation](https://github.com/Nameless0l/laravel-api-generator-vscode#readme)."
      }
    ],
    "walkthroughs": [
      {
        "id": "laravelApiGenerator.gettingStarted",
        "title": "Get Started with Laravel API Generator",
        "description": "Generate complete REST APIs for Laravel — from a form, your database, a schema file or a Mermaid diagram.",
        "steps": [
          {
            "id": "installPackage",
            "title": "Install the Composer package",
            "description": "The extension drives the nameless/laravel-api-generator package (v3.5+).\n[Open a Terminal](command:workbench.action.terminal.new)",
            "media": {
              "markdown": "media/walkthrough/install.md"
            }
          },
          {
            "id": "firstApi",
            "title": "Generate your first API",
            "description": "Describe an entity in the visual form and generate its 12 files in one click.\n[Open the Generator](command:laravelApiGenerator.generate)",
            "media": {
              "markdown": "media/walkthrough/first-api.md"
            },
            "completionEvents": [
              "onCommand:laravelApiGenerator.generate"
            ]
          },
          {
            "id": "fromDatabase",
            "title": "Import an existing database",
            "description": "Point the generator at your schema and get APIs for every table — relationships included.\n[Generate from Database](command:laravelApiGenerator.generateFromDatabase)",
            "media": {
              "markdown": "media/walkthrough/from-database.md"
            },
            "completionEvents": [
              "onCommand:laravelApiGenerator.generateFromDatabase",
              "onCommand:laravelApiGenerator.generateFromSchema",
              "onCommand:laravelApiGenerator.generateFromMermaid"
            ]
          },
          {
            "id": "exploreSidebar",
            "title": "Explore the sidebar",
            "description": "Browse generated entities, jump between related files and manage your APIs.\n[Show Generated Entities](command:laravelApiGenerator.entities.focus)",
            "media": {
              "markdown": "media/walkthrough/explore.md"
            },
            "completionEvents": [
              "onView:laravelApiGenerator.entities"
            ]
          }
        ]
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "laravelApiGenerator.regenerateFile",
          "when": "view == laravelApiGenerator.entities && viewItem == entity",
          "group": "inline@1"
        },
        {
          "command": "laravelApiGenerator.delete",
          "when": "view == laravelApiGenerator.entities && viewItem == entity",
          "group": "inline@2"
        },
        {
          "command": "laravelApiGenerator.addFields",
          "when": "view == laravelApiGenerator.entities && viewItem == entity",
          "group": "1_evolve@1"
        }
      ],
      "view/title": [
        {
          "command": "laravelApiGenerator.generate",
          "when": "view == laravelApiGenerator.entities",
          "group": "navigation@1"
        },
        {
          "command": "laravelApiGenerator.generateFromDatabase",
          "when": "view == laravelApiGenerator.entities",
          "group": "1_sources@1"
        },
        {
          "command": "laravelApiGenerator.generateFromSchema",
          "when": "view == laravelApiGenerator.entities",
          "group": "1_sources@2"
        },
        {
          "command": "laravelApiGenerator.generateFromMermaid",
          "when": "view == laravelApiGenerator.entities",
          "group": "1_sources@3"
        },
        {
          "command": "laravelApiGenerator.diagram",
          "when": "view == laravelApiGenerator.entities",
          "group": "navigation@2"
        },
        {
          "command": "laravelApiGenerator.showSnippets",
          "when": "view == laravelApiGenerator.entities",
          "group": "navigation@3"
        },
        {
          "command": "laravelApiGenerator.refresh",
          "when": "view == laravelApiGenerator.entities",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Laravel API Generator",
      "properties": {
        "laravelApiGenerator.phpPath": {
          "type": "string",
          "default": "php",
          "description": "Path to the PHP executable"
        },
        "laravelApiGenerator.locale": {
          "type": "string",
          "enum": ["auto", "en", "fr"],
          "default": "auto",
          "enumDescriptions": [
            "Follow VS Code display language",
            "English",
            "Français"
          ],
          "description": "Display language for the Laravel API Generator UI and messages"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"out/test/*.test.js\"",
    "package": "vsce package",
    "publish:marketplace": "vsce publish",
    "publish:openvsx": "npx ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
