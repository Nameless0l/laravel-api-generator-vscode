    },
    "LAG: Filter Scope": {
        "prefix": "lag:filter",
        "scope": "php",
        "body": [
            "public function scopeFilter(Builder \\$query, array \\$filters): Builder",
            "{",
            "    foreach (\\$filters as \\$field => \\$value) {",
            "        if (in_array(\\$field, \\$this->getFillable(), true)) {",
            "            \\$query->where(\\$field, \\$value);",
            "        }",
            "    }",
            "    return \\$query;",
            "}"
        ],
        "description": "Generate a filter query scope"
    }
}
