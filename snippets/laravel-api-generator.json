{
    "LAG: Service Class": {
        "prefix": "lag:service",
        "scope": "php",
        "body": [
            "<?php",
            "",
            "declare(strict_types=1);",
            "",
            "namespace App\\\\Services;",
            "",
            "use App\\\\Models\\\\${1:Name};",
            "use App\\\\DTO\\\\${1:Name}DTO;",
            "use Illuminate\\\\Support\\\\Collection;",
            "",
            "class ${1:Name}Service",
            "{",
            "    public function getAll(array \\$filters = []): Collection",
            "    {",
            "        \\$query = ${1:Name}::query();",
            "        foreach (\\$filters as \\$field => \\$value) {",
            "            if (in_array(\\$field, (new ${1:Name}())->getFillable(), true)) {",
            "                \\$query->where(\\$field, \\$value);",
            "            }",
            "        }",
            "        return \\$query->get();",
            "    }",
            "",
            "    public function create(${1:Name}DTO \\$dto): ${1:Name}",
            "    {",
            "        return ${1:Name}::create(get_object_vars(\\$dto));",
            "    }",
            "",
            "    public function find(int \\$id): ${1:Name}",
            "    {",
            "        return ${1:Name}::findOrFail(\\$id);",
            "    }",
            "",
            "    public function update(${1:Name} \\$${2:model}, ${1:Name}DTO \\$dto): ${1:Name}",
            "    {",
            "        \\$${2:model}->update(get_object_vars(\\$dto));",
            "        return \\$${2:model}->fresh();",
            "    }",
            "",
            "    public function delete(${1:Name} \\$${2:model}): bool",
            "    {",
            "        return \\$${2:model}->delete();",
            "    }",
            "}"
        ],
        "description": "Generate a Laravel API service class"
    },
    "LAG: DTO Class": {
        "prefix": "lag:dto",
        "scope": "php",
        "body": [
            "<?php",
            "",
            "declare(strict_types=1);",
            "",
            "namespace App\\\\DTO;",
            "",
            "use App\\\\Http\\\\Requests\\\\${1:Name}Request;",
            "",
            "readonly class ${1:Name}DTO",
            "{",
            "    public function __construct(",
            "        ${2:public ?string \\$field,}",
            "    ) {}",
            "",
            "    public static function fromRequest(${1:Name}Request \\$request): self",
            "    {",
            "        return new self(",
            "            ${3:\\$request->input('field'),}",
            "        );",
            "    }",
            "}"
        ],
        "description": "Generate a Laravel API DTO class"
    },
    "LAG: Controller Class": {
        "prefix": "lag:controller",
        "scope": "php",
        "body": [
            "<?php",
            "",
            "declare(strict_types=1);",
            "",
            "namespace App\\\\Http\\\\Controllers;",
            "",
            "use App\\\\Models\\\\${1:Name};",
            "use App\\\\Services\\\\${1:Name}Service;",
            "use App\\\\DTO\\\\${1:Name}DTO;",
            "use App\\\\Http\\\\Requests\\\\${1:Name}Request;",
            "use App\\\\Http\\\\Resources\\\\${1:Name}Resource;",
            "use Illuminate\\\\Http\\\\Request;",
            "",
            "class ${1:Name}Controller extends Controller",
            "{",
            "    public function __construct(",
            "        private readonly ${1:Name}Service \\$service",
            "    ) {}",
            "",
            "    public function index(Request \\$request)",
            "    {",
            "        \\$items = \\$this->service->getAll(\\$request->query());",
            "        return ${1:Name}Resource::collection(\\$items);",
            "    }",
            "",
            "    public function store(${1:Name}Request \\$request)",
            "    {",
            "        \\$dto = ${1:Name}DTO::fromRequest(\\$request);",
            "        \\$item = \\$this->service->create(\\$dto);",
            "        return new ${1:Name}Resource(\\$item);",
            "    }",
            "",
            "    public function show(${1:Name} \\$${2:model})",
            "    {",
            "        return new ${1:Name}Resource(\\$${2:model});",
            "    }",
            "",
            "    public function update(${1:Name}Request \\$request, ${1:Name} \\$${2:model})",
            "    {",
            "        \\$dto = ${1:Name}DTO::fromRequest(\\$request);",
            "        \\$updated = \\$this->service->update(\\$${2:model}, \\$dto);",
            "        return new ${1:Name}Resource(\\$updated);",
            "    }",
            "",
            "    public function destroy(${1:Name} \\$${2:model})",
            "    {",
            "        \\$this->service->delete(\\$${2:model});",
            "        return response(null, 204);",
            "    }",
            "}"
        ],
        "description": "Generate a Laravel API controller class"
    },
    "LAG: Form Request": {
        "prefix": "lag:request",
        "scope": "php",
        "body": [
            "<?php",
            "",
            "declare(strict_types=1);",
            "",
            "namespace App\\\\Http\\\\Requests;",
            "",
            "use Illuminate\\\\Foundation\\\\Http\\\\FormRequest;",
            "",
            "class ${1:Name}Request extends FormRequest",
            "{",
